# Copy to /etc/zabbix/bitrix_alerts.env and chmod 600.
# Do not commit real secrets.

# Incoming webhook base URL (Developer resources → Incoming webhooks).
# Scope must include imbot; enable methods imbot.v2.Bot.register and imbot.v2.Chat.Message.send.
# You may paste either the REST base or the old im.message.add URL — the script strips /im.message.add(.json).
BITRIX_WEBHOOK_URL="https://your-domain.bitrix24.com/rest/1/xxxxxxxx/"

# Chat dialog ID, e.g. chat123 for a group chat (see README). For a private DM use numeric user ID only.
BITRIX_DIALOG_ID="chat123"

# Bot identity (imbot.v2.Bot.register). CODE must be unique per webhook app; TOKEN is your secret for API calls.
BITRIX_BOT_CODE="zabbix_alerts"
BITRIX_BOT_TOKEN="<generate e.g. openssl rand -hex 32>"
BITRIX_BOT_NAME="Zabbix"
BITRIX_BOT_WORK_POSITION="Monitoring bot"

# Optional: fixed bot ID (skip register/cache). Otherwise bot_id is obtained on first run and cached.
# BITRIX_BOT_ID=123

# Optional: cache file for bot numeric ID (default /var/lib/zabbix/bitrix_bot_id). Directory must be writable by zabbix.
# BITRIX_BOT_ID_CACHE="/var/lib/zabbix/bitrix_bot_id"

# Optional: directory for local log files (default /var/log/zabbix).
# LOG_DIR="/var/log/zabbix"

# Optional: override path to env file (default /etc/zabbix/bitrix_alerts.env).
# BITRIX_ALERTS_ENV_FILE="/etc/zabbix/bitrix_alerts.env"
